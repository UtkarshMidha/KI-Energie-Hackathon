    }
  ],

  "eligibility_rules": [
    {
      "rule_id": "NDS_001",
      "if": {
        "pv_capacity_kw": {
          "gt": 0
        }
      },
      "eligible_for": [
        "federal_incentives",
        "municipal_incentives"
      ]
    },

    {
      "rule_id": "NDS_002",
      "if": {
        "building_type": "commercial"
      },
      "eligible_for": [
        "nbank_business_programs"
      ]
    },

    {
      "rule_id": "NDS_003",
      "if": {
        "building_type": "industrial"
      },
      "eligible_for": [
        "nbank_business_programs"
      ]
    },

    {
      "rule_id": "NDS_004",
      "if": {
        "energy_cooperative": true
      },
      "eligible_for": [
        "climate_protection_programs"
      ]
    }
  ],

  "braunschweig_specific": {
    "municipal_support_possible": true,
    "categories": [
      "balcony_pv",
      "vertical_pv",
      "community_energy"
    ]
