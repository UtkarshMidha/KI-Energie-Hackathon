  "grid_connection_rules": [
    {
      "rule_id": "ENWG_17_001",
      "section": "17",
      "title": "Right to grid connection",
      "topic": "grid_connection",
      "requirement": {
        "grid_operator_must_connect": true,
        "conditions": [
          "reasonable",
          "transparent",
          "non_discriminatory"
        ]
      }
    },
    {
      "rule_id": "ENWG_17_002",
      "section": "17",
      "title": "Storage connection",
      "topic": "battery_storage",
      "requirement": {
        "battery_connection_allowed": true
      }
    }
  ],

  "flexible_connection_rules": [
    {
      "rule_id": "ENWG_17_2B_001",
      "section": "17(2b)",
      "topic": "flexible_connection_agreement",
      "requirement": {
        "agreement_possible": true
      }
    },
    {
      "rule_id": "ENWG_17_2B_002",
      "section": "17(2b)",
      "topic": "capacity_limitation",
      "requirement": {
        "static_limitation_allowed": true,
        "dynamic_limitation_allowed": true
      }
    },
    {
      "rule_id": "ENWG_17_2B_003",
      "section": "17(2b)",
      "topic": "minimum_contract_content",
      "required_fields": [
        "capacity_limit",
        "time_windows",
        "agreement_duration",
        "technical_requirements"
      ]
    }
  ],

  "section_14a": {
    "description": "Grid-oriented control of controllable devices",

    "applicable_devices": [
      {
        "device": "heat_pump",
        "controllable": true
      },
      {
        "device": "ev_charger",
        "controllable": true
      },
      {
        "device": "battery_storage",
        "controllable": true
      },
      {
        "device": "air_conditioning",
        "controllable": true
      }
    ],

    "rules": [
      {
        "rule_id": "ENWG_14A_001",
        "topic": "remote_control_capability",
        "requirement": {
          "remote_controllability_required": true
        }
      },
      {
        "rule_id": "ENWG_14A_002",
        "topic": "grid_overload_protection",
        "requirement": {
          "dso_may_reduce_power": true
        }
      },
