    {
      "id": "OBJ_001",
      "name": "digitalization_of_energy_transition"
    },
    {
      "id": "OBJ_002",
      "name": "secure_metering"
    },
    {
      "id": "OBJ_003",
      "name": "data_protection"
    },
    {
      "id": "OBJ_004",
      "name": "grid_flexibility"
    },
    {
      "id": "OBJ_005",
      "name": "renewable_integration"
    }
  ],

  "definitions": [
    {
      "id": "modern_meter",
      "german": "moderne Messeinrichtung",
      "abbreviation": "mME",
      "description": "Digital electricity meter without gateway communication"
    },
    {
      "id": "smart_meter_gateway",
      "german": "Smart-Meter-Gateway",
      "abbreviation": "SMGW",
      "description": "Secure communication unit connecting meters and energy market participants"
    },
    {
      "id": "intelligent_metering_system",
      "german": "intelligentes Messsystem",
      "abbreviation": "iMSys",
      "description": "Modern meter combined with certified Smart Meter Gateway"
    },
    {
      "id": "metering_point_operator",
      "german": "Messstellenbetreiber",
      "abbreviation": "MSB"
    },
    {
      "id": "default_metering_point_operator",
      "german": "grundzuständiger Messstellenbetreiber",
      "abbreviation": "gMSB"
    }
  ],

  "metering_hierarchy": {
    "level_1": {
      "device": "modern_meter",
      "communication": false
    },
    "level_2": {
      "device": "intelligent_metering_system",
      "communication": true,
      "gateway_required": true
    }
  },

  "smart_meter_rollout": [
    {
      "rule_id": "MSBG_ROLLOUT_001",
      "topic": "mandatory_rollout",
      "requirement": {
        "rollout_required": true
      }
    },
    {
      "rule_id": "MSBG_ROLLOUT_002",
      "topic": "consumer_above_6000_kwh",
      "condition": {
        "annual_consumption_kwh": ">6000"
      },
      "requirement": {
        "imsys_required": true
      }
    },
    {
      "rule_id": "MSBG_ROLLOUT_003",
      "topic": "small_consumers",
      "condition": {
        "annual_consumption_kwh": "<=6000"
      },
      "requirement": {
        "modern_meter_sufficient": true
      }
    }
  ],

  "pv_specific_rules": [
    {
      "rule_id": "MSBG_PV_001",
      "topic": "pv_above_7kw",
      "condition": {
        "pv_capacity_kw": ">7"
      },
      "requirement": {
        "imsys_required": true
      }
    },
    {
      "rule_id": "MSBG_PV_002",
      "topic": "renewable_integration",
      "requirement": {
        "gateway_connectable": true
      }
    },
    {
      "rule_id": "MSBG_PV_003",
      "topic": "remote_metering",
      "requirement": {
        "remote_reading_allowed": true
      }
    }
  ],

  "section_14a_interaction": [
